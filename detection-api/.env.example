# 服务器配置
PORT=8000
NODE_ENV=development
HOST=localhost

# 数据库配置
DATABASE_PATH=./data/portal.db
DATABASE_MEMORY=false

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# CORS配置
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
CORS_MODE=lan

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# 检测配置
MAX_SCAN_DEPTH=5
SCAN_TIMEOUT_MS=30000
MAX_CONCURRENT_SCANS=3

# 端口配置
FRONTEND_PORT_START=3001
FRONTEND_PORT_END=3020
BACKEND_PORT_START=4001
BACKEND_PORT_END=4020

# 缓存配置
CACHE_TTL_SECONDS=300
CACHE_MAX_KEYS=1000

# PM2集成配置
# Windows 下 PM2 默认禁用，设置为 1 启用 PM2 进程管理功能
PM2_ENABLED=1

# 安全增强配置
AUTH_ENFORCEMENT=on
TRUST_PROXY=1
HELMET_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX=30
REQUEST_BODY_LIMIT=5mb

# 高危操作二次确认（PM2 写操作）
PM2_CONFIRMATION_REQUIRED=true
PM2_CONFIRMATION_TOKEN=replace-with-random-confirmation-token

# 路径白名单（逗号或分号分隔绝对路径）
# 未配置时默认仅允许当前工作目录及 data/logs/temp/uploads
PATH_SECURITY_BASE_PATHS=
FILESYSTEM_ALLOWED_BASE_PATHS=
ALLOW_WORKSPACE_PARENT=false

# WebSocket 安全
WS_AUTH_REQUIRED=true
WS_ALLOW_QUERY_TOKEN=false

# 公开端点开关（生产建议保持 false）
ENABLE_PUBLIC_MONITORING=false
ENABLE_PUBLIC_SYSTEM_ENDPOINTS=false
ENABLE_V2_PUBLIC_ANONYMOUS=false

# 管理员MFA（可选）
ADMIN_MFA_REQUIRED=false
# ADMIN_MFA_TOTP_SECRET=BASE32_SECRET
