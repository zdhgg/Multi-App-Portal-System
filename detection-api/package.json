{
  "name": "detection-api",
  "version": "1.2.0",
  "description": "智能多Web应用门户系统 - Clean Architecture API服务",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "cross-env PM2_ENABLED=1 tsx watch src/server.ts",
    "build": "tsc --skipLibCheck || echo Build completed with warnings",
    "build:prod": "tsc -p tsconfig.prod.json",
    "build:check": "tsc --noEmit",
    "start": "cross-env PM2_ENABLED=1 tsx src/server.ts",
    "start:prod": "cross-env PM2_ENABLED=1 node dist/server.js",
    "migrate": "tsx src/scripts/migrate-database.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts --fix",
    "format": "prettier --write src/",
    "setup:dev": "cp ../config/development.env .env",
    "setup:prod": "cp ../config/production.env .env"
  },
  "dependencies": {
    "@types/archiver": "^6.0.3",
    "@types/multer": "^2.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/redis": "^4.0.10",
    "@types/ws": "^8.18.1",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.2.0",
    "chokidar": "^3.5.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "express-validator": "^7.2.1",
    "fast-glob": "^3.3.0",
    "glob": "^10.3.0",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^3.0.5",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cache": "^5.1.0",
    "node-cron": "^4.2.1",
    "ping": "^0.4.4",
    "pm2": "^6.0.11",
    "redis": "^5.8.2",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "cross-env": "^7.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.7.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/http-proxy-middleware": "^0.19.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/morgan": "^1.9.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.57.0",
    "node-fetch": "^3.3.2",
    "prettier": "^3.1.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "portal",
    "detection",
    "web-apps",
    "typescript",
    "express"
  ]
}
