# 生产环境配置
NODE_ENV=production

# 服务器配置
PORT=8002
HOST=0.0.0.0

# 数据库配置
DB_PATH=./data/portal.db

# CORS配置
CORS_ORIGIN=https://your-domain.com
CORS_CREDENTIALS=true
CORS_MODE=strict
TRUST_PROXY=1

# 日志配置
LOG_LEVEL=warn

# JWT配置 - 生产环境必须使用32位以上随机密钥
JWT_SECRET=replace-this-with-random-64-char-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# WebSocket配置
WS_PORT=8002
WS_AUTH_REQUIRED=true
WS_ALLOW_QUERY_TOKEN=false

# API配置
API_TIMEOUT=15000
API_RETRY_COUNT=2

# 功能开关
ENABLE_SWAGGER=false
ENABLE_MONITORING=true
ENABLE_WEBSOCKET=true

# 安全配置
AUTH_ENFORCEMENT=on
HELMET_ENABLED=true
REQUEST_BODY_LIMIT=5mb
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX=30

# 高风险操作二次确认
PM2_CONFIRMATION_REQUIRED=true
PM2_CONFIRMATION_TOKEN=replace-with-random-confirmation-token

# 文件系统路径白名单（逗号或分号分隔绝对路径）
PATH_SECURITY_BASE_PATHS=
FILESYSTEM_ALLOWED_BASE_PATHS=
ALLOW_WORKSPACE_PARENT=false

# 公开监控端点开关（生产建议关闭）
ENABLE_PUBLIC_MONITORING=false
ENABLE_PUBLIC_SYSTEM_ENDPOINTS=false
ENABLE_V2_PUBLIC_ANONYMOUS=false

# 管理员MFA（推荐开启）
ADMIN_MFA_REQUIRED=true
