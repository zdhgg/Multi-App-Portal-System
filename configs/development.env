# 开发环境配置
NODE_ENV=development

# 服务器配置
PORT=8002
HOST=0.0.0.0

# 数据库配置
DB_PATH=./data/portal.db

# CORS配置
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true

# 日志配置
LOG_LEVEL=debug

# JWT配置
JWT_SECRET=development-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# WebSocket配置
WS_PORT=8002

# API配置
API_TIMEOUT=30000
API_RETRY_COUNT=3

# 功能开关
ENABLE_SWAGGER=true
ENABLE_MONITORING=true
ENABLE_WEBSOCKET=true

# PM2集成（Windows上默认禁用，需要显式启用）
# 注意：PM2在Windows上可能有命名管道权限问题
# 如果不需要PM2功能，保持未设置或设为0
PM2_ENABLED=1